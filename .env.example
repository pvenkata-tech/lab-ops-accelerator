# ── LLM provider selection ─────────────────────────────────────────────────────
# Which backend serves the reasoning model. All four map to the same unified
# tool schema, so swapping providers is a config change, not a code change.
# One of: bedrock | anthropic | gemini | openai
LLM_PROVIDER=bedrock

# ── AWS Bedrock (used when LLM_PROVIDER=bedrock; embeddings always use Bedrock) ─
AWS_REGION=us-east-1
BEDROCK_CLAUDE_MODEL_ID=us.anthropic.claude-sonnet-5
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSIONS=1024

# ── Anthropic — native API (used when LLM_PROVIDER=anthropic) ──────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-5

# ── Google Gemini (used when LLM_PROVIDER=gemini) ───────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-pro

# ── OpenAI (used when LLM_PROVIDER=openai) ──────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_ID=gpt-5.5

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://labops:labops@localhost:5432/labops
CHECKPOINT_DATABASE_URL=postgresql://labops:labops@localhost:5432/labops

# ── MCP client (orchestrator → LIMS/EHR MCP servers) ───────────────────────────
LIMS_MCP_SERVER_URL=http://localhost:9101/mcp
EHR_MCP_SERVER_URL=http://localhost:9102/mcp

# ── LIMS MCP server config (used by lab_ops_accelerator/mcp_servers/lims_server.py) ─
LIMS_API_BASE_URL=http://lims-mock:8001
LIMS_API_KEY=dev-lims-key

# ── EHR MCP server config (used by lab_ops_accelerator/mcp_servers/ehr_server.py) ──
EHR_WEBHOOK_URL=http://ehr-mock:8002/notify
EHR_API_KEY=dev-ehr-key

# ── Observability (optional, recommended for production) ──────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=lab-ops-accelerator

# ── Agent tuning ──────────────────────────────────────────────────────────────
# Disposition confidence below this threshold triggers HITL supervisor review
HITL_CONFIDENCE_THRESHOLD=0.80
